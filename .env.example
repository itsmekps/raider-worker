# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=debt-recovery-workers
KAFKA_TLS_ENABLED=false
# Only required when TLS is enabled:
# KAFKA_SASL_USER=
# KAFKA_SASL_PASSWORD=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Either set MONGO_URI directly, or use the discrete Atlas-style vars below
# (MONGODB_HOST takes precedence over MONGO_URI when set — builds a
# mongodb+srv:// URI automatically).
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=debt_recovery
MONGO_TLS_ENABLED=false
# MONGODB_HOST=cluster.xxxxx.mongodb.net
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_NAME=debt_recovery

# ── Redis ─────────────────────────────────────────────────────────────────────
# Either set REDIS_URI directly, or use the discrete vars below (REDIS_HOST
# takes precedence over REDIS_URI when set).
REDIS_URI=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Worker pool sizes ─────────────────────────────────────────────────────────
WORKER_CASE_COUNT=50
WORKER_PAYMENT_COUNT=20
WORKER_VISIT_COUNT=20
WORKER_NOTIFICATION_COUNT=50
WORKER_QUEUE_BUFFER_SIZE=10000

# ── Servers ───────────────────────────────────────────────────────────────────
HEALTH_PORT=8080
PROMETHEUS_PORT=9090

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Timeouts (milliseconds) ───────────────────────────────────────────────────
TIMEOUT_KAFKA_MS=30000
TIMEOUT_MONGO_MS=5000
TIMEOUT_REDIS_MS=2000
TIMEOUT_EXTERNAL_API_MS=10000

# ── Retry ─────────────────────────────────────────────────────────────────────
RETRY_MAX=5
